{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "brew-browser",
  "version": "0.2.1",
  "identifier": "dev.openbrew.browser",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "brew-browser",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 20 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://formulae.brew.sh https://api.github.com https://github.com https://brew-browser.zerologic.com https://objects.githubusercontent.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://brew-browser.zerologic.com/updater.json"
      ],
      "pubkey": "RWQAAAAAPLACEHOLDER_REPLACE_BEFORE_RELEASE_SEE_BUILD_MDxxxxxxxxxx"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Michael Sitarzewski (7JQGQ7CRH8)",
      "hardenedRuntime": true,
      "minimumSystemVersion": "13.0"
    }
  }
}
