# ─────────────────────────────────────────────────────────────────────────────
# brew-browser — root .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Rust build artifacts (BIG — multiple GB; never commit)
target/
src-tauri/target/

# Node deps + build output
node_modules/
/build
.svelte-kit/
/dist
/package
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Tauri generated platform projects (regeneratable; can be committed if desired,
# but for early-stage we let `tauri icon` produce them on demand)
src-tauri/gen/

# Secrets — pattern allowlist; *.example files are kept
.env
.env.local
.env.*.local
.env.*
!.env.example
*.pem
*.key

# Tool-local state (always regenerable)
tools/categorize/.venv/
tools/categorize/state/
tools/categorize/__pycache__/
tools/categorize/*.log

# Cargo deny temp downloads
src-tauri/.cargo/registry/
src-tauri/.cargo/git/

# Coverage / profiling
*.profraw
*.lcov

# OS noise
.DS_Store
Thumbs.db
*.swp
*~

# Editor noise
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json
.idea/
*.iml

# Python noise (the categorize tool)
__pycache__/
*.pyc

# Logs
*.log

# Icon previews — regenerable from docs/icon/brew-browser.svg via qlmanage
docs/icon/preview-*.png

# Build artifacts (never commit binaries)
*.AppImage
*.deb
*.rpm
*.dmg
*.app.tar.gz
*.app.tar.gz.sig
